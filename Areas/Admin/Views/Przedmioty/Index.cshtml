@model List<University_Admissions_Scoring_Engine.Models.Przedmiot>

<h1>Przedmioty</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<p class="d-flex gap-2">
    <a asp-action="Create" class="btn btn-primary">Dodaj przedmiot</a>
    <a asp-action="Warianty" class="btn btn-outline-secondary">Warianty przedmiotów</a>
</p>

<table class="table table-bordered align-middle">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nazwa</th>
            <th style="width:220px;">Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdPrzedmiot</td>
                <td>@item.Nazwa</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.IdPrzedmiot" class="btn btn-sm btn-outline-primary">Edytuj</a>

                        <form asp-action="Delete" method="post" onsubmit="return confirm('Usunąć przedmiot?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.IdPrzedmiot" />
                            <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>