@model University_Admissions_Scoring_Engine.ViewModels.PrzedmiotFormViewModel

<h1>Edytuj przedmiot</h1>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="IdPrzedmiot" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Nazwa" class="form-label"></label>
        <input asp-for="Nazwa" class="form-control" />
        <span asp-validation-for="Nazwa" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Zapisz zmiany</button>
        <a asp-action="Index" class="btn btn-secondary">Powrót</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}