@model University_Admissions_Scoring_Engine.ViewModels.AlgorytmKierunkiViewModel

<h1>Przypisz algorytm do kierunków</h1>

<div class="mb-3">
    <strong>Algorytm:</strong> @Model.Algorytm.Nazwa (@Model.Algorytm.IdAlgorytm)
</div>

<form asp-action="AssignToKierunki" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Algorytm.IdAlgorytm" />
    <input type="hidden" asp-for="Algorytm.Nazwa" />

    <div class="mb-3 d-flex gap-2 flex-wrap">
        <button type="button" class="btn btn-outline-primary" onclick="setAllKierunki(true)">
            Zaznacz wszystkie
        </button>

        <button type="button" class="btn btn-outline-secondary" onclick="setAllKierunki(false)">
            Odznacz wszystkie
        </button>
    </div>

    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th style="width: 90px;">Wybór</th>
                <th>Kierunek</th>
                <th>Tryb</th>
                <th>Rodzaj</th>
                <th>Aktualny algorytm</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var kierunek in Model.WszystkieKierunki)
            {
                var isChecked = Model.WybraneKierunkiIds.Contains(kierunek.IdKierunek);

                <tr>
                    <td>
                        <input type="checkbox"
                               class="js-kierunek-checkbox"
                               name="WybraneKierunkiIds"
                               value="@kierunek.IdKierunek"
                               @(isChecked ? "checked" : null) />
                    </td>
                    <td>@kierunek.Nazwa</td>
                    <td>@kierunek.Tryb?.Nazwa</td>
                    <td>@kierunek.Rodzaj?.Nazwa</td>
                    <td>
                        @if (kierunek.AlgorytmId == Model.Algorytm.IdAlgorytm)
                        {
                            <span>Ten algorytm</span>
                        }
                        else if (kierunek.Algorytm != null)
                        {
                            <span>@kierunek.Algorytm.Nazwa (@kierunek.Algorytm.IdAlgorytm)</span>
                        }
                        else
                        {
                            <span>Brak</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Zapisz przypisania</button>
        <a asp-action="Index" class="btn btn-secondary">Powrót</a>
    </div>
</form>

<script>
    function setAllKierunki(isChecked) {
        document.querySelectorAll('.js-kierunek-checkbox').forEach(cb => {
            cb.checked = isChecked;
        });
    }
</script>