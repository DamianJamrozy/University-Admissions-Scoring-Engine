<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - University Admissions Scoring Engine</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>

<body class="admin-body">
    <div class="admin-shell">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <div class="admin-brand-icon">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <div>
                    <div class="admin-brand-title">Admin Panel</div>
                    <div class="admin-brand-subtitle">Admissions Engine</div>
                </div>
            </div>

            <nav class="admin-nav">

                <!-- DASHBOARD -->
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="admin-nav-link">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Dashboard</span>
                </a>

                <div class="admin-nav-group-title">Moduły</div>

                <!-- ALGORYTMY -->
                <a asp-area="Admin" asp-controller="Algorytmy" asp-action="Index" class="admin-nav-link">
                    <i class="bi bi-diagram-3"></i>
                    <span>Algorytmy</span>
                </a>

                <!-- KIERUNKI -->
                <a asp-area="Admin" asp-controller="Kierunki" asp-action="Index" class="admin-nav-link">
                    <i class="bi bi-mortarboard"></i>
                    <span>Kierunki</span>
                </a>

                <!-- MATURY -->
                <a asp-area="Admin" asp-controller="Matury" asp-action="Index" class="admin-nav-link">
                    <i class="bi bi-journal-check"></i>
                    <span>Matury</span>
                </a>

                <!-- PRZEDMIOTY -->
                <a asp-area="Admin" asp-controller="Przedmioty" asp-action="Index" class="admin-nav-link">
                    <i class="bi bi-book"></i>
                    <span>Przedmioty</span>
                </a>

                <!-- RANKINGI -->
                <a asp-area="Admin" asp-controller="Rankingi" asp-action="Index" class="admin-nav-link">
                    <i class="bi bi-bar-chart-line"></i>
                    <span>Rankingi</span>
                </a>

                <div class="admin-nav-group-title">Rozwój</div>

                <!-- PLANOWANE (nie ruszamy!) -->
                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-folder2-open"></i>
                    <span>CMS treści</span>
                </a>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-ui-checks-grid"></i>
                    <span>Formularze</span>
                </a>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-translate"></i>
                    <span>Języki</span>
                </a>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-file-earmark-richtext"></i>
                    <span>Informator</span>
                </a>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-person-bounding-box"></i>
                    <span>Akceptacja zdjęć</span>
                </a>

            </nav>
        </aside>

        <!-- MAIN -->
        <div class="admin-main">

            <!-- TOPBAR -->
            <header class="admin-topbar">
                <div>
                    <h1 class="admin-topbar-title">@ViewData["Title"]</h1>
                    <div class="admin-topbar-subtitle">
                        Bezpieczne zarządzanie systemem rekrutacji
                    </div>
                </div>

                <div class="admin-topbar-actions">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-house-door me-1"></i> Strona główna
                    </a>
                </div>
            </header>

            <!-- CONTENT -->
            <main class="admin-content">
                @RenderBody()
            </main>

            <!-- FOOTER -->
            <footer class="admin-footer mt-4 text-center">
                <div>
                    © @DateTime.Now.Year
                    <a href="https://github.com/DamianJamrozy" target="_blank" rel="noopener noreferrer">
                        Damian Jamroży
                    </a>
                    — Wszystkie prawa zastrzeżone.
                </div>
            </footer>

        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>