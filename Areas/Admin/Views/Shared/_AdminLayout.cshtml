<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - University Admissions Scoring Engine</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <div class="admin-brand-icon">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <div>
                    <div class="admin-brand-title">Admin Panel</div>
                    <div class="admin-brand-subtitle">Admissions Engine</div>
                </div>
            </div>

            <nav class="admin-nav">
                <a class="admin-nav-link" href="/admin">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Dashboard</span>
                </a>

                <div class="admin-nav-group-title">Moduły</div>

                <a class="admin-nav-link" href="/Algorytmy">
                    <i class="bi bi-diagram-3"></i>
                    <span>Algorytmy</span>
                </a>

                <a class="admin-nav-link" href="/Kierunki">
                    <i class="bi bi-mortarboard"></i>
                    <span>Kierunki</span>
                </a>

                <a class="admin-nav-link" href="/Matury">
                    <i class="bi bi-journal-check"></i>
                    <span>Matury</span>
                </a>

                <a class="admin-nav-link" href="/Przedmioty">
                    <i class="bi bi-book"></i>
                    <span>Przedmioty</span>
                </a>

                <a class="admin-nav-link" href="/Rankingi">
                    <i class="bi bi-bar-chart-line"></i>
                    <span>Rankingi</span>
                </a>

                <div class="admin-nav-group-title">Rozwój</div>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-folder2-open"></i>
                    <span>CMS treści</span>
                </a>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-ui-checks-grid"></i>
                    <span>Formularze</span>
                </a>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-translate"></i>
                    <span>Języki</span>
                </a>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-file-earmark-richtext"></i>
                    <span>Informator</span>
                </a>

                <a class="admin-nav-link disabled" href="javascript:void(0)">
                    <i class="bi bi-person-bounding-box"></i>
                    <span>Akceptacja zdjęć</span>
                </a>
            </nav>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <div>
                    <h1 class="admin-topbar-title">@ViewData["Title"]</h1>
                    <div class="admin-topbar-subtitle">Bezpieczne zarządzanie systemem rekrutacji</div>
                </div>

                <div class="admin-topbar-actions">
                    <a href="/" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-house-door me-1"></i> Strona główna
                    </a>
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>