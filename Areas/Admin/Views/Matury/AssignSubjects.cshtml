@model University_Admissions_Scoring_Engine.ViewModels.MaturaPrzedmiotyViewModel

<h1>Przedmioty dla matury</h1>

<div class="mb-3">
    <strong>Matura:</strong> @Model.Matura.Nazwa
</div>

<form asp-action="AssignSubjects" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="maturaId" value="@Model.Matura.IdMatura" />

    <div class="mb-3 d-flex gap-2 flex-wrap">
        <button type="button" class="btn btn-outline-primary" onclick="setAllVariants(true)">Zaznacz wszystkie</button>
        <button type="button" class="btn btn-outline-secondary" onclick="setAllVariants(false)">Odznacz wszystkie</button>
    </div>

    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th style="width:90px;">Wybór</th>
                <th>Przedmiot</th>
                <th>Tryb</th>
                <th>Poziom</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.WszystkieWarianty)
            {
                var isChecked = Model.WybraneWariantyIds.Contains(item.IdPrzedmiotRodzajPoziom);

                <tr>
                    <td>
                        <input type="checkbox"
                               class="js-variant-checkbox"
                               name="wybraneWariantyIds"
                               value="@item.IdPrzedmiotRodzajPoziom"
                               @(isChecked ? "checked" : null) />
                    </td>
                    <td>@item.Przedmiot?.Nazwa</td>
                    <td>@item.PrzedmiotRodzaj?.Nazwa</td>
                    <td>@item.PrzedmiotPoziom?.Nazwa</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Zapisz</button>
        <a asp-action="Index" class="btn btn-secondary">Powrót</a>
    </div>
</form>

<script>
    function setAllVariants(isChecked) {
        document.querySelectorAll('.js-variant-checkbox').forEach(cb => cb.checked = isChecked);
    }
</script>