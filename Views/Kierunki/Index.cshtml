@model List<University_Admissions_Scoring_Engine.Models.Kierunek>

<h1>Kierunki</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Dodaj kierunek</a>
</p>

<table class="table table-bordered align-middle">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nazwa</th>
            <th>Tryb</th>
            <th>Rodzaj</th>
            <th>Min przyjętych</th>
            <th>Max przyjętych</th>
            <th>Max lista rezerwowa</th>
            <th>Algorytm</th>
            <th style="width: 220px;">Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdKierunek</td>
                <td>@item.Nazwa</td>
                <td>@item.Tryb?.Nazwa</td>
                <td>@item.Rodzaj?.Nazwa</td>
                <td>@item.MinPrzyjetych</td>
                <td>@item.MaxPrzyjetych</td>
                <td>@item.MaxListaRezerwowa</td>
                <td>
                    @if (item.Algorytm != null)
                    {
                        @($"{item.Algorytm.Nazwa} ({item.Algorytm.IdAlgorytm})")
                    }
                    else
                    {
                        <span>Brak</span>
                    }
                </td>
                <td>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Edit" asp-route-id="@item.IdKierunek" class="btn btn-sm btn-outline-primary">
                            Edytuj
                        </a>

                        <form asp-action="Delete" method="post" onsubmit="return confirm('Usunąć kierunek?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.IdKierunek" />
                            <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>