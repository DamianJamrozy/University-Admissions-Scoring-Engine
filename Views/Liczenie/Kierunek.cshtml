@model University_Admissions_Scoring_Engine.ViewModels.KierunekLiczenieViewModel

<h1>@Model.Kierunek.Nazwa</h1>

<p>
    Tryb: <strong>@Model.Kierunek.Tryb?.Nazwa</strong><br />
    Rodzaj: <strong>@Model.Kierunek.Rodzaj?.Nazwa</strong><br />
    Algorytm: <strong>@Model.Kierunek.Algorytm?.Nazwa</strong>
</p>

<form asp-action="Przelicz" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="kierunekId" value="@Model.Kierunek.IdKierunek" />
    <button type="submit" class="btn btn-success">Policz punkty i ranking</button>
    <a asp-action="Index" class="btn btn-secondary">Powrót</a>
</form>

<hr />

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Kandydat</th>
            <th>Punkty</th>
            <th>Ranking</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Kandydaci)
        {
            <tr>
                <td>@item.Kandydat?.Imie @item.Kandydat?.Nazwisko</td>
                <td>@item.Punkty</td>
                <td>@item.Ranking</td>
                <td>@item.Status?.Nazwa</td>
            </tr>
        }
    </tbody>
</table>