<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University Admissions Scoring Engine</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --app-bg: #f4f8fc;
            --app-surface: rgba(255, 255, 255, 0.82);
            --app-surface-strong: #ffffff;
            --app-border: rgba(226, 232, 240, 0.95);
            --app-text: #0f172a;
            --app-text-soft: #475569;
            --app-primary: #2563eb;
            --app-primary-dark: #1d4ed8;
            --app-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
            --app-radius-xl: 24px;
            --app-radius-lg: 18px;
            --app-radius-md: 14px;
        }

        html, body {
            min-height: 100%;
        }

        body {
            margin: 0;
            color: var(--app-text);
            background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 22%), radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.08), transparent 24%), linear-gradient(180deg, #f8fbff 0%, #eef5fb 100%);
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        .app-shell {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .app-topbar-wrap {
            position: sticky;
            top: 0;
            z-index: 1030;
            padding: 14px 18px 0 18px;
        }

        .app-topbar {
            max-width: 1440px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.82);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(226, 232, 240, 0.9);
            border-radius: 22px;
            box-shadow: 0 14px 40px rgba(15, 23, 42, 0.07);
            padding: 14px 20px;
        }

        .navbar-brand.app-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-right: 26px;
            font-weight: 800;
            color: var(--app-text) !important;
            letter-spacing: -0.02em;
        }

        .app-brand-mark {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1d4ed8 0%, #06b6d4 100%);
            color: #fff;
            font-size: 1.1rem;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.24);
            flex-shrink: 0;
        }

        .app-brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .app-brand-title {
            font-size: 1rem;
            font-weight: 800;
        }

        .app-brand-subtitle {
            font-size: 0.74rem;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .navbar-nav .nav-link {
            color: #334155 !important;
            font-weight: 600;
            border-radius: 12px;
            padding: 10px 14px !important;
            transition: background 0.2s ease, color 0.2s ease;
        }

            .navbar-nav .nav-link:hover,
            .navbar-nav .nav-link:focus {
                background: rgba(37, 99, 235, 0.08);
                color: var(--app-primary-dark) !important;
            }

        .app-topbar-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .app-btn-admin {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid rgba(37, 99, 235, 0.15);
            background: linear-gradient(135deg, #1d4ed8 0%, #06b6d4 100%);
            color: #fff !important;
            text-decoration: none;
            padding: 10px 16px;
            border-radius: 14px;
            font-weight: 700;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .app-btn-admin:hover {
                transform: translateY(-1px);
                box-shadow: 0 14px 28px rgba(37, 99, 235, 0.22);
                color: #fff !important;
                text-decoration: none;
            }

        .app-main {
            flex: 1;
            width: 100%;
            max-width: 1440px;
            margin: 0 auto;
            padding: 24px 18px 28px 18px;
        }

        .app-footer-wrap {
            padding: 0 18px 18px 18px;
        }

        .app-footer {
            max-width: 1440px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.78);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(226, 232, 240, 0.9);
            border-radius: 18px;
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.06);
            padding: 14px 18px;
            color: #64748b;
            font-size: 0.95rem;
            display: flex;
            justify-content: space-between;
            gap: 14px;
            flex-wrap: wrap;
        }

            .app-footer a {
                color: var(--app-primary-dark);
                text-decoration: none;
                font-weight: 700;
            }

                .app-footer a:hover {
                    text-decoration: underline;
                }

        @@media (max-width: 991.98px) {
            .app-topbar-wrap {
                padding: 12px 12px 0 12px;
            }

            .app-topbar {
                padding: 12px 14px;
            }

            .app-main {
                padding: 18px 12px 22px 12px;
            }

            .app-footer-wrap {
                padding: 0 12px 12px 12px;
            }

            .app-footer {
                padding: 12px 14px;
            }

            .app-topbar-right {
                margin-top: 10px;
            }
        }
    </style>
</head>
<body>
    <div class="app-shell">
        <div class="app-topbar-wrap">
            <header class="app-topbar">
                <nav class="navbar navbar-expand-lg p-0">
                    <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                        <span class="app-brand-mark">
                            <i class="bi bi-mortarboard-fill"></i>
                        </span>
                        <span class="app-brand-text">
                            <span class="app-brand-title">University Admissions Scoring Engine</span>
                            <span class="app-brand-subtitle">System Rekrutacyjny</span>
                        </span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                            aria-controls="mainNavbar" aria-expanded="false" aria-label="Przełącz nawigację">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Start</a>
                            </li>

                        </ul>

                        <div class="app-topbar-right">
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="app-btn-admin">
                                <i class="bi bi-shield-lock"></i>
                                <span>Panel administratora</span>
                            </a>
                        </div>
                    </div>
                </nav>
            </header>
        </div>

        <main class="app-main">
            @RenderBody()
        </main>

        <div class="app-footer-wrap">
            <footer class="app-footer">
                <div>
                    © @DateTime.Now.Year University Admissions Scoring Engine
                </div>
                <div>
                    Autor:
                    <a href="https://github.com/DamianJamrozy" target="_blank" rel="noopener noreferrer">Damian Jamroży</a>
                    — Wszystkie prawa zastrzeżone.
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>