@model University_Admissions_Scoring_Engine.ViewModels.PrzedmiotWariantFormViewModel

<h1>Dodaj wariant przedmiotu</h1>

<form asp-action="CreateWariant" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="PrzedmiotId" class="form-label"></label>
        <select asp-for="PrzedmiotId" asp-items="Model.Przedmioty" class="form-select"></select>
        <span asp-validation-for="PrzedmiotId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PrzedmiotRodzajId" class="form-label"></label>
        <select asp-for="PrzedmiotRodzajId" asp-items="Model.Rodzaje" class="form-select"></select>
        <span asp-validation-for="PrzedmiotRodzajId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PrzedmiotPoziomId" class="form-label"></label>
        <select asp-for="PrzedmiotPoziomId" asp-items="Model.Poziomy" class="form-select"></select>
        <span asp-validation-for="PrzedmiotPoziomId" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Zapisz</button>
        <a asp-action="Warianty" class="btn btn-secondary">Powrót</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}