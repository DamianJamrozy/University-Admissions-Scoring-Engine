@model List<University_Admissions_Scoring_Engine.Models.PrzedmiotRodzajPoziom>

<h1>Warianty przedmiotów</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<p class="d-flex gap-2">
    <a asp-action="CreateWariant" class="btn btn-primary">Dodaj wariant</a>
    <a asp-action="Index" class="btn btn-secondary">Powrót do przedmiotów</a>
</p>

<table class="table table-bordered align-middle">
    <thead>
        <tr>
            <th>ID</th>
            <th>Przedmiot</th>
            <th>Tryb</th>
            <th>Poziom</th>
            <th style="width:220px;">Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdPrzedmiotRodzajPoziom</td>
                <td>@item.Przedmiot?.Nazwa</td>
                <td>@item.PrzedmiotRodzaj?.Nazwa</td>
                <td>@item.PrzedmiotPoziom?.Nazwa</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="EditWariant" asp-route-id="@item.IdPrzedmiotRodzajPoziom" class="btn btn-sm btn-outline-primary">Edytuj</a>

                        <form asp-action="DeleteWariant" method="post" onsubmit="return confirm('Usunąć wariant?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.IdPrzedmiotRodzajPoziom" />
                            <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>