@model University_Admissions_Scoring_Engine.ViewModels.RankingDetailsViewModel

<h1>Ranking kierunku</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card mb-4">
    <div class="card-body">
        <h3>@Model.Kierunek.Nazwa</h3>

        <p class="mb-1"><strong>Tryb:</strong> @Model.Kierunek.Tryb?.Nazwa</p>
        <p class="mb-1"><strong>Rodzaj:</strong> @Model.Kierunek.Rodzaj?.Nazwa</p>
        <p class="mb-1"><strong>Liczba kandydatów:</strong> @Model.LiczbaKandydatow</p>
        <p class="mb-1">
            <strong>Algorytm:</strong>
            @if (Model.CzyMaAlgorytm)
            {
                @($"{Model.NazwaAlgorytmu} ({Model.Kierunek.AlgorytmId})")
            }
            else
            {
                <span>Brak przypisanego algorytmu</span>
            }
        </p>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-4">
    <form asp-action="CalculatePoints" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="kierunekId" value="@Model.Kierunek.IdKierunek" />
        <button type="submit" class="btn btn-outline-primary">Przelicz punkty</button>
    </form>

    <form asp-action="GenerateRanking" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="kierunekId" value="@Model.Kierunek.IdKierunek" />
        <button type="submit" class="btn btn-outline-secondary">Generuj ranking</button>
    </form>

    <form asp-action="RebuildAll" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="kierunekId" value="@Model.Kierunek.IdKierunek" />
        <button type="submit" class="btn btn-success">Przelicz wszystko</button>
    </form>

    <a asp-action="Index" class="btn btn-dark">Powrót</a>
</div>

@if (Model.LiczbaKandydatow < Model.Kierunek.MinPrzyjetych)
{
    <div class="alert alert-warning">
        Kierunek nie został uruchomiony – za mało kandydatów.
    </div>
}

<table class="table table-bordered table-striped align-middle">
    <thead>
        <tr>
            <th>Miejsce</th>
            <th>ID kandydata</th>
            <th>Imię</th>
            <th>Nazwisko</th>
            <th>Punkty</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.KandydaciNaKierunek.Any())
        {
            @foreach (var item in Model.KandydaciNaKierunek)
            {
                <tr>
                    <td>@(item.Ranking?.ToString() ?? "-")</td>
                    <td>@item.KandydatId</td>
                    <td>@item.Kandydat?.Imie</td>
                    <td>@item.Kandydat?.Nazwisko</td>
                    <td>@(item.Punkty?.ToString("0.##") ?? "-")</td>
                    <td>@item.Status?.Nazwa</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">Brak kandydatów na ten kierunek.</td>
            </tr>
        }
    </tbody>
</table>