@model University_Admissions_Scoring_Engine.ViewModels.AlgorytmCreateViewModel

<h1>Dodaj algorytm</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Nazwa" class="form-label"></label>
        <input asp-for="Nazwa" class="form-control" />
        <span asp-validation-for="Nazwa" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a asp-action="Index" class="btn btn-secondary">Powrót</a>
</form>