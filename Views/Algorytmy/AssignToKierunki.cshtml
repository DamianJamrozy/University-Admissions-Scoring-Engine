@model University_Admissions_Scoring_Engine.ViewModels.AlgorytmKierunkiViewModel

<h1>Przypisz algorytm do kierunków</h1>

<div class="mb-3">
    <strong>Algorytm:</strong> @Model.Algorytm.Nazwa
</div>

<form asp-action="AssignToKierunki" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Algorytm.IdAlgorytm" />
    <input type="hidden" asp-for="Algorytm.Nazwa" />

    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th style="width: 80px;">Wybór</th>
                <th>Kierunek</th>
                <th>Tryb</th>
                <th>Rodzaj</th>
                <th>Aktualny algorytm</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var kierunek in Model.WszystkieKierunki)
            {
                var isChecked = Model.WybraneKierunkiIds.Contains(kierunek.IdKierunek);

                <tr>
                    <td>
                        <input type="checkbox"
                               name="WybraneKierunkiIds"
                               value="@kierunek.IdKierunek"
                               @(isChecked ? "checked" : null) />
                    </td>
                    <td>@kierunek.Nazwa</td>
                    <td>@kierunek.Tryb?.Nazwa</td>
                    <td>@kierunek.Rodzaj?.Nazwa</td>
                    <td>
                        @(kierunek.AlgorytmId == Model.Algorytm.IdAlgorytm ? "Ten algorytm" : $"ID: {kierunek.AlgorytmId}")
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Zapisz przypisania</button>
        <a asp-action="Index" class="btn btn-secondary">Powrót</a>
    </div>
</form>