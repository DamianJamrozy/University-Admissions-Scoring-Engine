@model University_Admissions_Scoring_Engine.ViewModels.AlgorytmGroupTreeNodeViewModel

@{
    var children = Model.AllGroups
        .Where(x => x.RodzicId == Model.CurrentGroup.IdAlgorytmGrupa)
        .OrderBy(x => x.IdAlgorytmGrupa)
        .ToList();

    var elements = Model.AllElements
        .Where(x => x.AlgorytmGrupaId == Model.CurrentGroup.IdAlgorytmGrupa)
        .ToList();

    var subjectBlocks = elements
        .GroupBy(x => x.PrzedmiotRodzajPoziom!.PrzedmiotId)
        .OrderBy(g => g.First().PrzedmiotRodzajPoziom!.Przedmiot!.Nazwa)
        .ToList();

    var subjects = Model.PrzedmiotOpcje
        .GroupBy(x => x.PrzedmiotId)
        .Select(g => new
        {
            SubjectId = g.Key,
            SubjectName = g.First().Przedmiot!.Nazwa
        })
        .OrderBy(x => x.SubjectName)
        .ToList();

    var currentNo = Model.GroupNumbers[Model.CurrentGroup.IdAlgorytmGrupa];
    int? parentNo = null;

    if (Model.CurrentGroup.RodzicId.HasValue && Model.GroupNumbers.ContainsKey(Model.CurrentGroup.RodzicId.Value))
    {
        parentNo = Model.GroupNumbers[Model.CurrentGroup.RodzicId.Value];
    }

    var cssClass = Model.IsRoot ? "group root" : "group";
}

<div class="@cssClass">
    <div class="group-card">
        <div class="group-header">
            <div class="group-title">
                <span class="group-number">Grupa @currentNo</span>

                @if (parentNo != null)
                {
                    <span class="group-parent">| rodzic: grupa @parentNo</span>
                }
            </div>

            <div class="group-toolbar">
                <button type="button"
                        class="btn btn-sm btn-outline-primary"
                        onclick="addGroup(@Model.AlgorytmMaturaId, @Model.CurrentGroup.IdAlgorytmGrupa, window.currentAlgorytmId, window.currentMaturaId)">
                    + grupa
                </button>

                <button type="button"
                        class="btn btn-sm btn-outline-success"
                        onclick="addElement(@Model.CurrentGroup.IdAlgorytmGrupa, window.currentAlgorytmId, window.currentMaturaId)">
                    + element
                </button>

                <button type="button"
                        class="btn btn-sm btn-outline-danger"
                        onclick="deleteGroup(@Model.CurrentGroup.IdAlgorytmGrupa, window.currentAlgorytmId, window.currentMaturaId)">
                    Usuń
                </button>
            </div>
        </div>

        <div class="group-operation-row d-flex gap-3 flex-wrap align-items-center">
            <select class="form-select js-group-op" data-group-id="@Model.CurrentGroup.IdAlgorytmGrupa">
                @foreach (var op in Model.Operacje.OrderBy(x => x.Nazwa))
                {
                    if (op.IdAlgorytmOperacja == Model.CurrentGroup.AlgorytmOperacjaId)
                    {
                        <option selected value="@op.IdAlgorytmOperacja">@op.Nazwa</option>
                    }
                    else
                    {
                        <option value="@op.IdAlgorytmOperacja">@op.Nazwa</option>
                    }
                }
            </select>

            <div style="width: 150px;">
                <input type="number"
                       step="0.01"
                       class="form-control js-group-min"
                       data-group-id="@Model.CurrentGroup.IdAlgorytmGrupa"
                       placeholder="Min. grupy"
                       value="@(Model.CurrentGroup.MinimalnePunkty?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")" />
            </div>
        </div>

        @if (subjectBlocks.Any())
        {
            <div class="elements-wrap">
                @foreach (var subjectBlock in subjectBlocks)
                {
                    var subjectId = subjectBlock.Key;
                    var subjectName = subjectBlock.First().PrzedmiotRodzajPoziom?.Przedmiot?.Nazwa ?? "-";

                    <div class="element-card js-subject-block" data-group-id="@Model.CurrentGroup.IdAlgorytmGrupa">
                        <div class="d-flex gap-2 align-items-start justify-content-between flex-wrap mb-3">
                            <div style="flex:1; min-width:320px;">
                                <div class="subject-picker custom-picker">
                                    <input type="hidden" class="js-subject-id" value="@subjectId" />

                                    <button type="button" class="subject-trigger custom-picker-trigger">
                                        <span class="subject-trigger-label custom-picker-label">@subjectName</span>
                                        <span>▾</span>
                                    </button>

                                    <div class="subject-dropdown custom-picker-dropdown">
                                        <div class="subject-search-wrap">
                                            <input type="text" class="subject-search-input custom-picker-search" placeholder="Szukaj przedmiotu..." />
                                        </div>

                                        <div class="subject-options">
                                            @foreach (var s in subjects)
                                            {
                                                <div class="subject-option custom-picker-option @(s.SubjectId == subjectId ? "active" : "")"
                                                     data-value="@s.SubjectId"
                                                     data-label="@s.SubjectName">
                                                    @s.SubjectName
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary"
                                        onclick="addCombination(@Model.CurrentGroup.IdAlgorytmGrupa, @subjectId, window.currentAlgorytmId, window.currentMaturaId)">
                                    + kombinacja
                                </button>

                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        onclick="deleteSubjectBlock(@Model.CurrentGroup.IdAlgorytmGrupa, @subjectId, window.currentAlgorytmId, window.currentMaturaId)">
                                    Usuń przedmiot
                                </button>
                            </div>
                        </div>

                        <div class="d-flex flex-column gap-2">
                            @foreach (var e in subjectBlock.OrderBy(x => x.PrzedmiotRodzajPoziom!.PrzedmiotRodzaj!.Nazwa)
                                                .ThenBy(x => x.PrzedmiotRodzajPoziom!.PrzedmiotPoziom!.Nazwa))
                            {
                                var combosForSubject = Model.PrzedmiotOpcje
                                .Where(x => x.PrzedmiotId == subjectId)
                                .ToList();

                                var availableRodzaje = combosForSubject
                                .Select(x => x.PrzedmiotRodzaj!)
                                .DistinctBy(x => x.IdPrzedmiotRodzaj)
                                .OrderBy(x => x.Nazwa)
                                .ToList();

                                var availablePoziomy = combosForSubject
                                .Select(x => x.PrzedmiotPoziom!)
                                .DistinctBy(x => x.IdPrzedmiotPoziom)
                                .OrderBy(x => x.Nazwa)
                                .ToList();

                                <div class="js-element-row d-grid align-items-center gap-2"
                                     data-element-id="@e.IdAlgorytmLicz"
                                     style="grid-template-columns: 170px 170px 90px 120px 110px 150px;">
                                    <div>
                                        <select class="form-select js-rodzaj-id">
                                            @foreach (var r in availableRodzaje)
                                            {
                                                if (r.IdPrzedmiotRodzaj == e.PrzedmiotRodzajPoziom!.PrzedmiotRodzajId)
                                                {
                                                    <option selected value="@r.IdPrzedmiotRodzaj">@r.Nazwa</option>
                                                }
                                                else
                                                {
                                                    <option value="@r.IdPrzedmiotRodzaj">@r.Nazwa</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div>
                                        <select class="form-select js-poziom-id">
                                            @foreach (var p in availablePoziomy)
                                            {
                                                if (p.IdPrzedmiotPoziom == e.PrzedmiotRodzajPoziom!.PrzedmiotPoziomId)
                                                {
                                                    <option selected value="@p.IdPrzedmiotPoziom">@p.Nazwa</option>
                                                }
                                                else
                                                {
                                                    <option value="@p.IdPrzedmiotPoziom">@p.Nazwa</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div>
                                        <input type="number"
                                               step="0.01"
                                               value="@e.Liczba.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                               class="form-control js-multiplier"
                                               placeholder="Mnożnik" />
                                    </div>

                                    <div class="form-check d-flex align-items-center" style="min-height:42px;">
                                        <input class="form-check-input js-required"
                                               type="checkbox"
                                               @(e.CzyWymagany ? "checked" : null)
                                               style="margin-top:0;" />
                                        <label class="form-check-label ms-2">
                                            Wymagany
                                        </label>
                                    </div>

                                    <div>
                                        <input type="number"
                                               step="0.01"
                                               value="@(e.MinimalnePunkty?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                               class="form-control js-element-min"
                                               placeholder="Min. pkt" />
                                    </div>

                                    <div class="element-actions-right">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="deleteElement(@e.IdAlgorytmLicz, window.currentAlgorytmId, window.currentMaturaId)">
                                            Usuń
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @if (children.Any())
        {
            <div class="children-wrap">
                @foreach (var child in children)
                {
                    @await Html.PartialAsync("_AlgorytmEditorNode", new University_Admissions_Scoring_Engine.ViewModels.AlgorytmGroupTreeNodeViewModel
                    {
                        CurrentGroup = child,
                        AllGroups = Model.AllGroups,
                        AllElements = Model.AllElements,
                        Operacje = Model.Operacje,
                        PrzedmiotOpcje = Model.PrzedmiotOpcje,
                        AlgorytmId = Model.AlgorytmId,
                        AlgorytmMaturaId = Model.AlgorytmMaturaId,
                        IsRoot = false,
                        GroupNumbers = Model.GroupNumbers
                        })
                        }
            </div>
        }
    </div>
</div>